<!DOCTYPE html>
<html lang="en">

<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>ChatWith</title>
   <link rel="preconnect" href="https://fonts.googleapis.com">
   <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
   <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
   <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
   <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

   <link rel="stylesheet" href="/dashboard.css">
</head>

<body>
   <div id="main">
      <div id="id1">

         <div id="heading">
            <span>ChatWith</span>
            <a id="logout" href="/user/logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
         </div>

         <h4 class="section-title">All Users Of ChatWith</h4>
         <div id="chats">
            <div class="user-card ai-card" data-email="AI" data-name="Swayam">
               <div class="user-info">
                  <span class="user-name">
                     Swayam <i class="fa-solid fa-robot"></i>
                  </span>
               </div>
            </div>
            
            <% all.forEach(element=> { %>
               <% if (element.Email !==user?.email) { %>
                  <div class="user-card" data-email="<%= element.Email %>" data-name="<%= element.Name %>">
                     <div class="user-info">
                        <span class="user-name">
                           <%= element.Name %>
                        </span>
                        <span class="user-email">
                           <%= element.Email %>
                        </span>
                     </div>
                     <div class="status-indicator" title="Offline"></div>
                  </div>
                  <% } %>
                     <% }) %>
         </div>

         <!-- logged in user -->
         <div id="current-user-info">
            <i class="fa-solid fa-circle-user"></i>
            <div class="user-details">
               <span class="name">
                  <%= user?.name %>
               </span>
               <span class="email">
                  <%= user?.email || "Ai" %>
               </span>
            </div>
         </div>
      </div>

      <div id="id2">
         <div class="welcome-screen">
            <i class="fa-solid fa-comments"></i>
            <h3>Welcome to ChatWith, <%= user?.name %>!</h3>
            <p>Select a user from the sidebar to start chatting, or click on <strong>Swayam</strong> to talk with the AI assistant.</p>
         </div>
      </div>
   </div>

   <script>
      const loggedInUserEmail = "<%= user?.email %>";
      const loggedInUserName = "<%= user?.name %>";
   </script>
   <script src="/socket.io/socket.io.js"></script>
   <script src="/dashboard.js"></script>
</body>

</html>